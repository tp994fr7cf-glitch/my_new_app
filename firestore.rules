rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validWritableApplicationStatus(status) {
      return status in ['none', 'pending'];
    }

    function validExistingOrWritableApplicationStatus(newStatus, oldStatus) {
      return newStatus == oldStatus
        || newStatus in ['none', 'pending']
        || (newStatus == null && oldStatus == null);
    }

    function validTeacherApplicationStatusUpdate() {
      return request.resource.data.teacherApplicationStatus == resource.data.teacherApplicationStatus
        || ((resource.data.teacherApplicationStatus == null
          || resource.data.teacherApplicationStatus == 'none'
          || resource.data.teacherApplicationStatus == 'pending')
          && request.resource.data.teacherApplicationStatus == 'pending');
    }

    function validTeacherApplication() {
      return !request.resource.data.keys().hasAny(['teacherApplication'])
        || request.resource.data.teacherApplication is map;
    }

    function hasInitialStudentRole() {
      return request.resource.data.roles is list
        && request.resource.data.roles.size() == 1
        && request.resource.data.roles[0] == 'student'
        && request.resource.data.activeRole == 'student';
    }

    function keepsExistingRoles() {
      return request.resource.data.roles == resource.data.roles
        && request.resource.data.activeRole in resource.data.roles;
    }

    function onlyUpdatesTeacherApplicationFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'intendedUse',
        'teacherApplicationStatus',
        'teacherApplication',
        'updatedAt'
      ]);
    }

    function canSubmitTeacherApplication(userId) {
      return isOwner(userId)
        && onlyUpdatesTeacherApplicationFields()
        && request.resource.data.intendedUse == 'teacher'
        && request.resource.data.teacherApplicationStatus == 'pending'
        && (resource.data.teacherApplicationStatus == null
          || resource.data.teacherApplicationStatus == 'none'
          || resource.data.teacherApplicationStatus == 'pending')
        && validTeacherApplication();
    }

    function hasActiveTeacherRole() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['teacher'])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeRole == 'teacher';
    }

    function isTeacher() {
      return hasActiveTeacherRole();
    }

    function validCoursePrivacyPolicyMap(data) {
      return !data.keys().hasAny(['privacyPolicy'])
        || (data.privacyPolicy is map
          && data.privacyPolicy.shareLegalNameWithInstructor is bool
          && data.privacyPolicy.shareLegalNameAmongLearners is bool
          && data.privacyPolicy.consentPolicyVersion is int
          && data.privacyPolicy.consentPolicyVersion >= 1
          && (data.privacyPolicy.shareLegalNameAmongLearners == false
            || data.privacyPolicy.shareLegalNameWithInstructor == true)
          && (!data.privacyPolicy.keys().hasAny(['updatedAt'])
            || data.privacyPolicy.updatedAt is timestamp));
    }

    function validCourseLessonCount(data) {
      return data.lessons is list
        && data.lessonCount is int
        && data.lessonCount >= 0
        && data.lessonCount == data.lessons.size();
    }

    function validCourseLessonUpdateInvariant() {
      return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['lessons', 'lessonCount'])
        || validCourseLessonCount(request.resource.data);
    }

    function validLessonContentVersionUpdate() {
      let changesLessons = request.resource.data.diff(resource.data)
        .affectedKeys().hasAny(['lessons']);
      let hadVersion = resource.data.keys()
        .hasAny(['lessonContentVersion']);
      let hasVersion = request.resource.data.keys()
        .hasAny(['lessonContentVersion']);
      return (!changesLessons
          && hadVersion == hasVersion
          && (!hadVersion
            || (resource.data.lessonContentVersion is int
              && resource.data.lessonContentVersion >= 1
              && resource.data.lessonContentVersion <= 2147483647
              && request.resource.data.lessonContentVersion
                == resource.data.lessonContentVersion)))
        || (changesLessons
          && request.resource.data.lessonContentVersion is int
          && request.resource.data.lessonContentVersion >= 1
          && request.resource.data.lessonContentVersion <= 2147483647
          && ((!hadVersion
              && request.resource.data.lessonContentVersion == 1)
            || (hadVersion
              && resource.data.lessonContentVersion is int
              && resource.data.lessonContentVersion >= 1
              && resource.data.lessonContentVersion < 2147483647
              && request.resource.data.lessonContentVersion
                == resource.data.lessonContentVersion + 1)));
    }

    function validLessonContentVersionCreate() {
      return !request.resource.data.keys()
          .hasAny(['lessonContentVersion'])
        || (request.resource.data.lessonContentVersion is int
          && request.resource.data.lessonContentVersion == 1);
    }

    function canUpdateOwnTeacherCourse() {
      return isTeacher()
        && resource.data.instructorId == request.auth.uid
        && request.resource.data.instructorId == resource.data.instructorId
        && request.resource.data.courseCode == resource.data.courseCode
        && request.resource.data.source == resource.data.source
        && request.resource.data.status == resource.data.status
        && request.resource.data.lessons is list
        && request.resource.data.lessonCount is int
        && validCourseLessonUpdateInvariant()
        && validLessonContentVersionUpdate()
        && validCoursePrivacyPolicyMap(request.resource.data);
    }

    // Rules can bound these collections, but cannot iterate dynamic segment IDs
    // or validate every value in the resume-position map. The reader filters
    // malformed entries and the writer emits only finite, non-negative values.
    function validOptionalLessonSessionProgress(data) {
      return (!data.keys().hasAny(['playbackMode'])
          || data.playbackMode in [
            'continuous',
            'independentSingle',
            'independentPanels'
          ])
        && (!data.keys().hasAny(['contentRevision'])
          || (data.contentRevision is int
            && data.contentRevision >= 1
            && data.contentRevision <= 2147483647))
        && (!data.keys().hasAny(['requiredMediaSegmentIds'])
          || (data.requiredMediaSegmentIds is list
            && data.requiredMediaSegmentIds.size() <= 500))
        && (!data.keys().hasAny(['completedMediaSegmentIds'])
          || (data.completedMediaSegmentIds is list
            && data.completedMediaSegmentIds.size() <= 500))
        && (!data.keys().hasAny(['mediaSegmentResumePositionsSec'])
          || (data.mediaSegmentResumePositionsSec is map
            && data.mediaSegmentResumePositionsSec.size() <= 500));
    }

    function validOptionalQuizVersion(data) {
      return !data.keys().hasAny(['quizVersion'])
        || (data.quizVersion is int
          && data.quizVersion >= 1
          && data.quizVersion <= 2147483647);
    }

    function validOptionalQuizSegmentMetadata(data) {
      return (!data.keys().hasAny(['anchorType'])
          || data.anchorType in ['global', 'segment'])
        && (!data.keys().hasAny(['segmentId'])
          || (data.segmentId is string && data.segmentId.size() > 0))
        && (!data.keys().hasAny(['timestampSec'])
          || (data.timestampSec is int && data.timestampSec >= 0))
        && (!data.keys().hasAny(['globalTimestampSec'])
          || (data.globalTimestampSec is int
            && data.globalTimestampSec >= 0));
    }

    function isCourseInstructor(courseId) {
      return hasActiveTeacherRole()
        && exists(/databases/$(database)/documents/courses/$(courseId))
        && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid;
    }

    function userHasCourseEnrollment(courseId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrollments/$(courseId));
    }

    function coursePolicyAllowsInstructorLegalNameShare(courseId) {
      return exists(/databases/$(database)/documents/courses/$(courseId))
        && get(/databases/$(database)/documents/courses/$(courseId)).data.keys().hasAny(['privacyPolicy'])
        && get(/databases/$(database)/documents/courses/$(courseId)).data.privacyPolicy is map
        && get(/databases/$(database)/documents/courses/$(courseId)).data.privacyPolicy.shareLegalNameWithInstructor == true;
    }

    function coursePolicyAllowsPeerLegalNameShare(courseId) {
      return exists(/databases/$(database)/documents/courses/$(courseId))
        && get(/databases/$(database)/documents/courses/$(courseId)).data.keys().hasAny(['privacyPolicy'])
        && get(/databases/$(database)/documents/courses/$(courseId)).data.privacyPolicy is map
        && get(/databases/$(database)/documents/courses/$(courseId)).data.privacyPolicy.shareLegalNameAmongLearners == true;
    }

    function validLegalNameValue(value) {
      return value is string
        && value.size() > 0
        && value.size() <= 80;
    }

    function validLegalNameOnCreate() {
      return (!request.resource.data.keys().hasAny(['legalName'])
          && !request.resource.data.keys().hasAny(['legalNameLockedAt']))
        || (request.resource.data.keys().hasAny(['legalName'])
          && request.resource.data.keys().hasAny(['legalNameLockedAt'])
          && validLegalNameValue(request.resource.data.legalName)
          && request.resource.data.legalNameLockedAt is timestamp);
    }

    function legalNameUnchangedOrInitialSet() {
      let hadLegalName = resource.data.keys().hasAny(['legalName'])
        && validLegalNameValue(resource.data.legalName);
      let hasLegalName = request.resource.data.keys().hasAny(['legalName'])
        && validLegalNameValue(request.resource.data.legalName);
      return (!hadLegalName
          && !hasLegalName
          && !request.resource.data.keys().hasAny(['legalNameLockedAt']))
        || (!hadLegalName
          && hasLegalName
          && request.resource.data.keys().hasAny(['legalNameLockedAt'])
          && request.resource.data.legalNameLockedAt is timestamp)
        || (hadLegalName
          && hasLegalName
          && request.resource.data.legalName == resource.data.legalName
          && request.resource.data.legalNameLockedAt == resource.data.legalNameLockedAt);
    }

    function lessonNotesPublicEnabled(settingId) {
      return settingId is string
        && (!exists(/databases/$(database)/documents/lessonInteractionSettings/$(settingId))
          || get(/databases/$(database)/documents/lessonInteractionSettings/$(settingId)).data.lessonNotesPublicEnabled != false);
    }

    function lessonQuestionsPublicEnabled(settingId) {
      return settingId is string
        && (!exists(/databases/$(database)/documents/lessonInteractionSettings/$(settingId))
          || get(/databases/$(database)/documents/lessonInteractionSettings/$(settingId)).data.lessonQuestionsPublicEnabled != false);
    }

    function learnerRestrictionModeForLearner(settingId, learnerId) {
      return signedIn()
        && settingId is string
        && learnerId is string
        && exists(/databases/$(database)/documents/lessonInteractionSettings/$(settingId)/learnerRestrictions/$(learnerId))
        && get(/databases/$(database)/documents/lessonInteractionSettings/$(settingId)/learnerRestrictions/$(learnerId)).data.restrictionMode in ['none', 'noPublicPost', 'noPublicReadOrPost']
          ? get(/databases/$(database)/documents/lessonInteractionSettings/$(settingId)/learnerRestrictions/$(learnerId)).data.restrictionMode
          : 'none';
    }

    function learnerRestrictionMode(settingId) {
      return learnerRestrictionModeForLearner(settingId, request.auth.uid);
    }

    function learnerPublicReadBlocked(settingId) {
      return learnerRestrictionMode(settingId) == 'noPublicReadOrPost';
    }

    function learnerPublicPostBlocked(settingId) {
      let mode = learnerRestrictionMode(settingId);
      return mode == 'noPublicPost' || mode == 'noPublicReadOrPost';
    }

    function learnerPublicPostBlockedForLearner(settingId, learnerId) {
      let mode = learnerRestrictionModeForLearner(settingId, learnerId);
      return mode == 'noPublicPost' || mode == 'noPublicReadOrPost';
    }

    function allowsQuestionCitationOnPublicNote(noteId, courseId, lessonNumber) {
      return noteId is string
        && exists(/databases/$(database)/documents/publicLessonNotes/$(noteId))
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.courseId == courseId
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.lessonNumber == lessonNumber
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.studentVisibility == 'public'
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.moderationStatus == 'visible'
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.isDeleted == false
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.allowsQuestionCitation == true
        && lessonNotesPublicEnabled(get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.interactionSettingId);
    }

    function allowsQuestionCitationOnTeacherOnlyPublicNote(noteId, courseId, lessonNumber) {
      return signedIn()
        && noteId is string
        && exists(/databases/$(database)/documents/publicLessonNotes/$(noteId))
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.courseId == courseId
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.lessonNumber == lessonNumber
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.studentVisibility == 'teacherOnly'
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.moderationStatus == 'visible'
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.isDeleted == false
        && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.allowsQuestionCitation == true
        && isCourseInstructor(get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.courseId);
    }

    function allowsQuestionCitationOnOwnNote(noteId, courseId, lessonNumber) {
      return signedIn()
        && noteId is string
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/lessonNotes/$(noteId))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/lessonNotes/$(noteId)).data.courseId == courseId
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/lessonNotes/$(noteId)).data.lessonNumber == lessonNumber
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/lessonNotes/$(noteId)).data.isDeleted == false
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/lessonNotes/$(noteId)).data.allowsQuestionCitation == true;
    }

    function noQuotedNoteFields() {
      return (!request.resource.data.keys().hasAny(['quotedNoteId'])
          || request.resource.data.quotedNoteId == null)
        && (!request.resource.data.keys().hasAny(['quotedNoteTitle'])
          || request.resource.data.quotedNoteTitle == null)
        && (!request.resource.data.keys().hasAny(['quotedNoteBody'])
          || request.resource.data.quotedNoteBody == null);
    }

    function quotedNoteSnapshotFieldEmpty(rawValue, hasField) {
      return !hasField || rawValue == '' || rawValue == null;
    }

    function quotedPublicNoteSnapshotMatches(noteId) {
      let noteData = get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data;
      let noteTitle = noteData.title;
      let noteBody = noteData.body;
      return ((noteTitle is string
            && noteTitle.size() > 0
            && request.resource.data.quotedNoteTitle == noteTitle)
          || (quotedNoteSnapshotFieldEmpty(
              noteTitle,
              noteData.keys().hasAny(['title']))
            && (!request.resource.data.keys().hasAny(['quotedNoteTitle'])
              || request.resource.data.quotedNoteTitle == null)))
        && ((noteBody is string
            && noteBody.size() > 0
            && request.resource.data.quotedNoteBody == noteBody)
          || (quotedNoteSnapshotFieldEmpty(
              noteBody,
              noteData.keys().hasAny(['body']))
            && (!request.resource.data.keys().hasAny(['quotedNoteBody'])
              || request.resource.data.quotedNoteBody == null)));
    }

    function quotedOwnNoteSnapshotMatches(noteId) {
      let noteData = get(/databases/$(database)/documents/users/$(request.auth.uid)/lessonNotes/$(noteId)).data;
      let noteTitle = noteData.title;
      let noteBody = noteData.body;
      return ((noteTitle is string
            && noteTitle.size() > 0
            && request.resource.data.quotedNoteTitle == noteTitle)
          || (quotedNoteSnapshotFieldEmpty(
              noteTitle,
              noteData.keys().hasAny(['title']))
            && (!request.resource.data.keys().hasAny(['quotedNoteTitle'])
              || request.resource.data.quotedNoteTitle == null)))
        && ((noteBody is string
            && noteBody.size() > 0
            && request.resource.data.quotedNoteBody == noteBody)
          || (quotedNoteSnapshotFieldEmpty(
              noteBody,
              noteData.keys().hasAny(['body']))
            && (!request.resource.data.keys().hasAny(['quotedNoteBody'])
              || request.resource.data.quotedNoteBody == null)));
    }

    function validQuotedNoteCitationForPublicAudience(courseId, lessonNumber) {
      return noQuotedNoteFields()
        || (request.resource.data.quotedNoteId is string
          && allowsQuestionCitationOnPublicNote(
            request.resource.data.quotedNoteId,
            courseId,
            lessonNumber
          )
          && quotedPublicNoteSnapshotMatches(request.resource.data.quotedNoteId));
    }

    function validQuotedNoteCitationForTeacherAudience(courseId, lessonNumber) {
      return noQuotedNoteFields()
        || (request.resource.data.quotedNoteId is string
          && (
            (allowsQuestionCitationOnPublicNote(
                request.resource.data.quotedNoteId,
                courseId,
                lessonNumber
              )
              && quotedPublicNoteSnapshotMatches(request.resource.data.quotedNoteId))
            || (allowsQuestionCitationOnTeacherOnlyPublicNote(
                request.resource.data.quotedNoteId,
                courseId,
                lessonNumber
              )
              && quotedPublicNoteSnapshotMatches(request.resource.data.quotedNoteId))
            || (allowsQuestionCitationOnOwnNote(
                request.resource.data.quotedNoteId,
                courseId,
                lessonNumber
              )
              && quotedOwnNoteSnapshotMatches(request.resource.data.quotedNoteId))
          ));
    }

    function validPublicUserProfile(profileId) {
      return request.resource.data.keys().hasOnly([
          'userId',
          'role',
          'displayName',
          'avatarColorName',
          'bio',
          'updatedAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role in ['student', 'teacher']
        && profileId == request.auth.uid + '_' + request.resource.data.role
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.avatarColorName in [
          'blue',
          'green',
          'orange',
          'purple',
          'pink',
          'teal',
          'brown',
          'indigo'
        ]
        && request.resource.data.bio is string
        && request.resource.data.bio.size() <= 160;
    }

    function validAuthorAvatarColorName(value) {
      return value in [
        'blue',
        'green',
        'orange',
        'purple',
        'pink',
        'teal',
        'brown',
        'indigo'
      ];
    }

    function canUpdateAuthorSnapshotForCourseContent() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'authorName',
          'authorAvatarColorName',
          'authorProfileVisible',
          'authorIdentityMode',
          'updatedAt'
        ])
        && request.resource.data.authorName is string
        && request.resource.data.authorAvatarColorName is string
        && validAuthorAvatarColorName(request.resource.data.authorAvatarColorName)
        && request.resource.data.authorProfileVisible is bool
        && request.resource.data.authorIdentityMode in ['profile', 'courseAlias']
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.courseId == resource.data.courseId
        && (
          resource.data.authorId == request.auth.uid
          || isCourseInstructor(resource.data.courseId)
        );
    }

    function canUpdateOwnAuthorSnapshotForCourseContent(userId) {
      return isOwner(userId)
        && canUpdateAuthorSnapshotForCourseContent()
        && resource.data.authorId == userId;
    }

    match /publicUserProfiles/{profileId} {
      allow read: if signedIn()
        && (
          profileId == request.auth.uid + '_student'
          || profileId.matches('^.+_teacher$')
        );
      allow create, update: if signedIn()
        && validPublicUserProfile(profileId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'student'
        && hasInitialStudentRole()
        && request.resource.data.status == 'active'
        && request.resource.data.intendedUse in ['learner', 'teacher', 'organization']
        && validWritableApplicationStatus(request.resource.data.teacherApplicationStatus)
        && validWritableApplicationStatus(request.resource.data.organizationApplicationStatus)
        && validTeacherApplication()
        && validLegalNameOnCreate();

      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && keepsExistingRoles()
        && request.resource.data.status == resource.data.status
        && request.resource.data.intendedUse in ['learner', 'teacher', 'organization']
        && validTeacherApplicationStatusUpdate()
        && validExistingOrWritableApplicationStatus(
          request.resource.data.organizationApplicationStatus,
          resource.data.organizationApplicationStatus
        )
        && validTeacherApplication()
        && legalNameUnchangedOrInitialSet();

      allow update: if canSubmitTeacherApplication(userId);

      match /enrollments/{courseId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.courseId == courseId
          && request.resource.data.status == 'inProgress'
          && request.resource.data.course is map
          && request.resource.data.lastLessonNumber is int
          && request.resource.data.lastLessonTitle is string;
      }

      match /coursePrivacyConsents/{courseId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.courseId == courseId
          && request.resource.data.userId == userId
          && request.resource.data.acceptedPolicyVersion is int
          && request.resource.data.acceptedPolicyVersion >= 1
          && request.resource.data.acceptedInstructorLegalNameShare is bool
          && request.resource.data.acceptedPeerLegalNameShare is bool
          && (request.resource.data.acceptedPeerLegalNameShare == false
            || request.resource.data.acceptedInstructorLegalNameShare == true)
          && (!request.resource.data.keys().hasAny(['peerShareToken'])
            || request.resource.data.peerShareToken == null
            || (request.resource.data.peerShareToken is string
              && request.resource.data.peerShareToken.size() >= 6
              && request.resource.data.peerShareToken.size() <= 120));

        allow delete: if isOwner(userId);
      }

      match /learningEvents/{eventId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.type == 'lessonOpened'
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string;
      }

      match /lessonViewSessions/{sessionId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.cycleNumber is int
          && request.resource.data.status in ['inProgress', 'completed']
          && request.resource.data.hasPlaybackStarted is bool
          && request.resource.data.pendingCompletion is bool
          && request.resource.data.maxWatchedPositionSec is int
          && request.resource.data.totalDurationSec is int
          && request.resource.data.completionThresholdSec is int
          && (!request.resource.data.keys().hasAny(['watchedRanges'])
            || request.resource.data.watchedRanges is list)
          && validOptionalLessonSessionProgress(request.resource.data);
      }

      match /lessonViewSegments/{segmentId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.sessionId is string
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.cycleNumber is int
          && request.resource.data.status in ['inProgress', 'completed']
          && request.resource.data.studySeconds is int
          && request.resource.data.watchSeconds is int
          && request.resource.data.startPositionSec is int
          && request.resource.data.endPositionSec is int
          && request.resource.data.isDeleted is bool;
      }

      match /learningTaskState/{stateId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && stateId == 'current'
          && request.resource.data.userId == userId
          && request.resource.data.taskKey is string
          && request.resource.data.sessionId is string
          && request.resource.data.segmentId is string
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.cycleNumber is int
          && request.resource.data.status in ['inProgress', 'completed'];
      }

      match /learningTaskEvents/{eventId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.taskKey is string
          && request.resource.data.sessionId is string
          && request.resource.data.segmentId is string
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.cycleNumber is int
          && request.resource.data.eventType in [
            'segmentStarted',
            'segmentResumed',
            'segmentCompleted'
          ];
      }

      match /activeLearningSession/{stateId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && stateId == 'current'
          && request.resource.data.userId == userId
          && request.resource.data.deviceId is string
          && request.resource.data.sessionId is string
          && request.resource.data.segmentId is string
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.cycleNumber is int
          && request.resource.data.status in ['active', 'inactive'];
      }

      match /quizAttempts/{attemptId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.eventId is string
          && request.resource.data.question is string
          && request.resource.data.selectedChoiceIndex is int
          && request.resource.data.correctChoiceIndex is int
          && request.resource.data.isCorrect is bool
          && validOptionalQuizVersion(request.resource.data)
          && validOptionalQuizSegmentMetadata(request.resource.data);
      }

      match /courseSearchHistory/{historyId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.keyword is string
          && request.resource.data.normalizedKeyword is string;
      }

      match /lessonNoteFolders/{folderId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.name is string
          && (!request.resource.data.keys().hasAny(['isDeleted'])
            || request.resource.data.isDeleted is bool);
      }

      match /lessonNotes/{noteId} {
        allow read: if isOwner(userId);

        function validLessonNoteOwnerWrite() {
          return request.resource.data.userId == userId
            && request.resource.data.authorId == userId
            && request.resource.data.title is string
            && request.resource.data.body is string
            && request.resource.data.folderId is string
            && request.resource.data.folderName is string
            && request.resource.data.courseId is string
            && request.resource.data.courseTitle is string
            && request.resource.data.lessonNumber is int
            && request.resource.data.lessonTitle is string
            && request.resource.data.visibility in ['private', 'teacherOnly', 'public']
            && request.resource.data.tags is list
            && request.resource.data.attachmentTypes is list
            && request.resource.data.hasAudioAttachment is bool
            && request.resource.data.isCopied is bool
            && request.resource.data.canPublish is bool
            && request.resource.data.allowsQuestionCitation is bool
            && (!request.resource.data.keys().hasAny(['citationEnabledAt'])
              || request.resource.data.citationEnabledAt is timestamp)
            && (!request.resource.data.keys().hasAny(['citationFreeEditUntil'])
              || request.resource.data.citationFreeEditUntil is timestamp)
            && (!request.resource.data.keys().hasAny(['citationEditCount'])
              || request.resource.data.citationEditCount is int)
            && (!request.resource.data.keys().hasAny(['lastCitationEditedAt'])
              || request.resource.data.lastCitationEditedAt is timestamp)
            && (request.resource.data.visibility == 'private'
              || request.resource.data.canPublish == true)
            && (!request.resource.data.keys().hasAny(['isDeleted'])
              || request.resource.data.isDeleted is bool)
            && (!request.resource.data.keys().hasAny(['moderationStatus'])
              || request.resource.data.moderationStatus in ['visible', 'hiddenByTeacher'])
            && (!request.resource.data.keys().hasAny(['publicApprovalStatus'])
              || request.resource.data.publicApprovalStatus in ['none', 'pending', 'approved', 'rejected'])
            && (request.resource.data.visibility == 'private'
              || (request.resource.data.hasAudioAttachment == false
                && request.resource.data.isCopied == false
                && request.resource.data.canPublish == true));
        }

        function instructorCanResolveLessonNoteApproval(userId) {
          return signedIn()
            && (resource.data.authorId == userId || resource.data.userId == userId)
            && (
              resource.data.instructorId == request.auth.uid
              || isCourseInstructor(resource.data.courseId)
            );
        }

        allow create: if isOwner(userId)
          && validLessonNoteOwnerWrite();

        allow update: if isOwner(userId)
          && validLessonNoteOwnerWrite()
          && (!resource.data.keys().hasAny(['allowsQuestionCitation'])
            || resource.data.allowsQuestionCitation != true
            || request.resource.data.allowsQuestionCitation == true)
          && ((!resource.data.keys().hasAny(['hasPublicMirror'])
              && resource.data.visibility != 'public'
              && resource.data.visibility != 'teacherOnly')
            || (resource.data.hasPublicMirror != true
              && resource.data.visibility != 'public'
              && resource.data.visibility != 'teacherOnly')
            || (resource.data.visibility == 'public'
              && request.resource.data.visibility == 'public')
            || (resource.data.visibility == 'teacherOnly'
              && request.resource.data.visibility == 'teacherOnly')
            || (resource.data.visibility != 'public'
              && resource.data.visibility != 'teacherOnly')
            || request.resource.data.isDeleted == true);

        allow update: if signedIn()
          && instructorCanResolveLessonNoteApproval(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'visibility',
            'publicApprovalStatus',
            'updatedAt'
          ])
          && resource.data.visibility == 'teacherOnly'
          && resource.data.publicApprovalStatus == 'pending'
          && request.resource.data.visibility == 'public'
          && request.resource.data.publicApprovalStatus == 'approved';

        allow update: if signedIn()
          && instructorCanResolveLessonNoteApproval(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'visibility',
            'publicApprovalStatus',
            'updatedAt'
          ])
          && resource.data.visibility == 'teacherOnly'
          && resource.data.publicApprovalStatus == 'pending'
          && request.resource.data.visibility == 'teacherOnly'
          && request.resource.data.publicApprovalStatus == 'rejected';

        allow update: if canUpdateOwnAuthorSnapshotForCourseContent(userId);
      }

      match /lessonQuestions/{questionId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.authorId == userId
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.title is string
          && request.resource.data.body is string
          && request.resource.data.visibility in ['teacherOnly', 'public']
          && request.resource.data.target in ['teacher', 'everyone']
          && request.resource.data.attachmentTypes is list
          && request.resource.data.isDeleted is bool
          && request.resource.data.moderationStatus in ['visible', 'hiddenByTeacher']
          && (
            (request.resource.data.visibility == 'public'
              || request.resource.data.target == 'everyone')
            ? validQuotedNoteCitationForPublicAudience(
                request.resource.data.courseId,
                request.resource.data.lessonNumber
              )
            : validQuotedNoteCitationForTeacherAudience(
                request.resource.data.courseId,
                request.resource.data.lessonNumber
              )
          );

        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'body',
            'updatedAt'
          ])
          && request.resource.data.body is string;

        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'isDeleted',
            'deletedAt',
            'updatedAt'
          ])
          && request.resource.data.isDeleted == true;

        allow update: if canUpdateOwnAuthorSnapshotForCourseContent(userId);
      }

      match /lessonQuestionAnswers/{answerId} {
        allow read: if isOwner(userId);

        function parentPublicQuestionExists(questionId) {
          return questionId is string
            && exists(/databases/$(database)/documents/publicLessonQuestions/$(questionId));
        }

        function parentPublicQuestionVisible(questionId) {
          return parentPublicQuestionExists(questionId)
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.moderationStatus == 'visible'
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.isDeleted == false;
        }

        function parentQuestionMatchesCourseLesson(questionId) {
          return parentPublicQuestionExists(questionId)
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.courseId == request.resource.data.courseId
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.lessonNumber == request.resource.data.lessonNumber;
        }

        function parentPublicQuestionAllowsLearnerAnswers(questionId) {
          return parentPublicQuestionVisible(questionId)
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'public'
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.target == 'everyone'
            && lessonQuestionsPublicEnabled(get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.interactionSettingId);
        }

        function parentPublicQuestionAuthorCanAnswer(questionId) {
          return parentPublicQuestionVisible(questionId)
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'public'
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorId == request.auth.uid
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorRole != 'teacher'
            && lessonQuestionsPublicEnabled(get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.interactionSettingId);
        }

        function parentTeacherOnlyQuestionAuthorCanAnswer(questionId) {
          return parentPublicQuestionVisible(questionId)
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'teacherOnly'
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorId == request.auth.uid
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorRole != 'teacher';
        }

        function parentQuestionInstructorCanAnswer(questionId) {
          return parentPublicQuestionExists(questionId)
            && isCourseInstructor(get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.courseId);
        }

        function parentPublicQuestionBlocksOtherLearnerAnswers(questionId) {
          return parentPublicQuestionVisible(questionId)
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'public'
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorRole != 'teacher'
            && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorId != request.auth.uid
            && !parentQuestionInstructorCanAnswer(questionId)
            && learnerPublicPostBlockedForLearner(
              get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.interactionSettingId,
              get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorId
            );
        }

        function parentQuestionAllowsWrite(questionId) {
          return parentPublicQuestionVisible(questionId)
            && parentQuestionMatchesCourseLesson(questionId)
            && !parentPublicQuestionBlocksOtherLearnerAnswers(questionId)
            && (
              (get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'public'
                && validQuotedNoteCitationForPublicAudience(
                  request.resource.data.courseId,
                  request.resource.data.lessonNumber
                )
                && (parentPublicQuestionAllowsLearnerAnswers(questionId)
                  || parentPublicQuestionAuthorCanAnswer(questionId)
                  || parentQuestionInstructorCanAnswer(questionId)))
              || (get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'teacherOnly'
                && validQuotedNoteCitationForTeacherAudience(
                  request.resource.data.courseId,
                  request.resource.data.lessonNumber
                )
                && (parentTeacherOnlyQuestionAuthorCanAnswer(questionId)
                  || parentQuestionInstructorCanAnswer(questionId)))
            );
        }

        allow create: if isOwner(userId)
          && request.resource.data.authorId == userId
          && request.resource.data.questionId is string
          && request.resource.data.courseId is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.body is string
          && request.resource.data.attachmentTypes is list
          && request.resource.data.isDeleted is bool
          && request.resource.data.moderationStatus in ['visible', 'hiddenByTeacher']
          && parentQuestionAllowsWrite(request.resource.data.questionId);

        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'isDeleted',
            'deletedAt',
            'updatedAt'
          ])
          && request.resource.data.isDeleted == true;

        allow update: if canUpdateOwnAuthorSnapshotForCourseContent(userId);
      }
    }

    match /publicLessonNotes/{noteId} {
      allow read: if signedIn()
        && (resource.data.authorId == request.auth.uid
          || isCourseInstructor(resource.data.courseId)
          || (resource.data.studentVisibility == 'public'
            && resource.data.moderationStatus == 'visible'
            && resource.data.isDeleted == false
            && lessonNotesPublicEnabled(resource.data.interactionSettingId)
            && !learnerPublicReadBlocked(resource.data.interactionSettingId)));

      function validPublicLessonNoteOwnerWrite() {
        return request.resource.data.userId == request.auth.uid
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.noteId == noteId
          && request.resource.data.title is string
          && request.resource.data.body is string
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.interactionSettingId is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.visibility == 'public'
          && request.resource.data.studentVisibility in ['private', 'teacherOnly', 'public']
          && request.resource.data.tags is list
          && request.resource.data.attachmentTypes is list
          && request.resource.data.allowsQuestionCitation is bool
          && (!request.resource.data.keys().hasAny(['citationEnabledAt'])
            || request.resource.data.citationEnabledAt is timestamp)
          && (!request.resource.data.keys().hasAny(['citationFreeEditUntil'])
            || request.resource.data.citationFreeEditUntil is timestamp)
          && (!request.resource.data.keys().hasAny(['citationEditCount'])
            || request.resource.data.citationEditCount is int)
          && (!request.resource.data.keys().hasAny(['lastCitationEditedAt'])
            || request.resource.data.lastCitationEditedAt is timestamp)
          && request.resource.data.hasAudioAttachment == false
          && request.resource.data.isCopied == false
          && request.resource.data.canPublish == true
          && (!request.resource.data.keys().hasAny(['isDeleted'])
            || request.resource.data.isDeleted is bool)
          && (!request.resource.data.keys().hasAny(['publicPublishedAt'])
            || request.resource.data.publicPublishedAt is timestamp)
          && (!request.resource.data.keys().hasAny(['moderationStatus'])
            || request.resource.data.moderationStatus in ['visible', 'hiddenByTeacher'])
          && (!request.resource.data.keys().hasAny(['publicApprovalStatus'])
            || request.resource.data.publicApprovalStatus in ['none', 'pending', 'approved', 'rejected']);
      }

      allow create: if signedIn()
        && validPublicLessonNoteOwnerWrite()
        && request.resource.data.studentVisibility in ['public', 'teacherOnly']
        && (request.resource.data.studentVisibility != 'public'
          || isCourseInstructor(request.resource.data.courseId)
          || !learnerPublicPostBlocked(request.resource.data.interactionSettingId))
        && (!request.resource.data.keys().hasAny(['moderationStatus'])
          || request.resource.data.moderationStatus == 'visible');

      allow update: if signedIn()
        && validPublicLessonNoteOwnerWrite()
        && resource.data.authorId == request.auth.uid
        && (request.resource.data.studentVisibility != 'public'
          || isCourseInstructor(request.resource.data.courseId)
          || !learnerPublicPostBlocked(request.resource.data.interactionSettingId))
        && (!resource.data.keys().hasAny(['allowsQuestionCitation'])
          || resource.data.allowsQuestionCitation != true
          || request.resource.data.allowsQuestionCitation == true)
        && request.resource.data.studentVisibility in ['public', 'teacherOnly']
        && (resource.data.studentVisibility != 'teacherOnly'
          || request.resource.data.studentVisibility == 'teacherOnly')
        && (resource.data.studentVisibility != 'public'
          || request.resource.data.studentVisibility == 'public')
        && ((!resource.data.keys().hasAny(['moderationStatus'])
          && (!request.resource.data.keys().hasAny(['moderationStatus'])
            || request.resource.data.moderationStatus == 'visible'))
          || (resource.data.keys().hasAny(['moderationStatus'])
            && request.resource.data.keys().hasAny(['moderationStatus'])
            && request.resource.data.moderationStatus == resource.data.moderationStatus));

      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'studentVisibility',
          'isDeleted',
          'deletedAt',
          'updatedAt'
        ])
        && request.resource.data.studentVisibility == 'private'
        && request.resource.data.isDeleted == true;

      function instructorCanResolvePublicLessonNoteApproval() {
        return resource.data.instructorId == request.auth.uid
          || isCourseInstructor(resource.data.courseId);
      }

      allow update: if signedIn()
        && instructorCanResolvePublicLessonNoteApproval()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'studentVisibility',
          'publicApprovalStatus',
          'publicPublishedAt',
          'updatedAt'
        ])
        && resource.data.studentVisibility == 'teacherOnly'
        && resource.data.publicApprovalStatus == 'pending'
        && request.resource.data.studentVisibility == 'public'
        && request.resource.data.publicApprovalStatus == 'approved';

      allow update: if signedIn()
        && instructorCanResolvePublicLessonNoteApproval()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'studentVisibility',
          'publicApprovalStatus',
          'updatedAt'
        ])
        && resource.data.studentVisibility == 'teacherOnly'
        && resource.data.publicApprovalStatus == 'pending'
        && request.resource.data.studentVisibility == 'teacherOnly'
        && request.resource.data.publicApprovalStatus == 'rejected';

      allow update: if signedIn()
        && isCourseInstructor(resource.data.courseId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'moderationStatus',
          'moderatedAt',
          'hiddenByTeacherIndividual',
          'hiddenByTeacherBulk'
        ])
        && request.resource.data.moderationStatus in ['visible', 'hiddenByTeacher'];

      allow update: if canUpdateAuthorSnapshotForCourseContent();

      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid
        && (!resource.data.keys().hasAny(['moderationStatus'])
          || resource.data.moderationStatus != 'hiddenByTeacher');

      match /editHistory/{historyId} {
        function readableParentPublicLessonNote() {
          return exists(/databases/$(database)/documents/publicLessonNotes/$(noteId))
            && (
              get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.authorId == request.auth.uid
              || isCourseInstructor(get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.courseId)
              || (
                get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.studentVisibility == 'public'
                && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.moderationStatus == 'visible'
                && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.isDeleted == false
                && lessonNotesPublicEnabled(get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.interactionSettingId)
              )
            );
        }

        function validPublicLessonNoteEditHistoryWrite() {
          return request.resource.data.noteId == noteId
            && request.resource.data.editedAt is timestamp
            && request.resource.data.countsTowardWeeklyLimit is bool
            && request.resource.data.compareAvailable is bool
            && (!request.resource.data.keys().hasAny(['beforeTitle'])
              || request.resource.data.beforeTitle == null
              || request.resource.data.beforeTitle is string)
            && (!request.resource.data.keys().hasAny(['beforeBody'])
              || request.resource.data.beforeBody == null
              || request.resource.data.beforeBody is string)
            && (!request.resource.data.keys().hasAny(['afterTitle'])
              || request.resource.data.afterTitle == null
              || request.resource.data.afterTitle is string)
            && (!request.resource.data.keys().hasAny(['afterBody'])
              || request.resource.data.afterBody == null
              || request.resource.data.afterBody is string)
            && (!request.resource.data.keys().hasAny(['compareVisibleUntil'])
              || request.resource.data.compareVisibleUntil == null
              || request.resource.data.compareVisibleUntil is timestamp)
            && (!request.resource.data.keys().hasAny(['purgedAt'])
              || request.resource.data.purgedAt is timestamp);
        }

        allow read: if signedIn()
          && readableParentPublicLessonNote();

        allow create, update: if signedIn()
          && exists(/databases/$(database)/documents/publicLessonNotes/$(noteId))
          && get(/databases/$(database)/documents/publicLessonNotes/$(noteId)).data.authorId == request.auth.uid
          && validPublicLessonNoteEditHistoryWrite();
      }
    }

    match /publicLessonQuestions/{questionId} {
      allow read: if signedIn()
        && ((resource.data.authorId == request.auth.uid
            && (!resource.data.keys().hasAny(['authorDisplayName'])
              || resource.data.authorDisplayName != '先生'
              || hasActiveTeacherRole()))
          || isCourseInstructor(resource.data.courseId)
          || (resource.data.studentVisibility == 'public'
            && resource.data.moderationStatus == 'visible'
            && resource.data.isDeleted == false
            && lessonQuestionsPublicEnabled(resource.data.interactionSettingId)
            && !learnerPublicReadBlocked(resource.data.interactionSettingId)));

      function validPublicLessonQuestionOwnerWrite() {
        return request.resource.data.userId == request.auth.uid
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.questionId == questionId
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.interactionSettingId is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.body is string
          && request.resource.data.visibility == 'public'
          && request.resource.data.studentVisibility in ['teacherOnly', 'public']
          && request.resource.data.target in ['teacher', 'everyone']
          && request.resource.data.attachmentTypes is list
          && request.resource.data.isDeleted is bool
          && request.resource.data.moderationStatus in ['visible', 'hiddenByTeacher']
          && (request.resource.data.target != 'everyone'
            || request.resource.data.studentVisibility == 'public')
          && (
            (request.resource.data.studentVisibility == 'public'
              || request.resource.data.target == 'everyone')
            ? validQuotedNoteCitationForPublicAudience(
                request.resource.data.courseId,
                request.resource.data.lessonNumber
              )
            : validQuotedNoteCitationForTeacherAudience(
                request.resource.data.courseId,
                request.resource.data.lessonNumber
              )
          );
      }

      allow create: if signedIn()
        && validPublicLessonQuestionOwnerWrite()
        && (request.resource.data.studentVisibility != 'public'
          || isCourseInstructor(request.resource.data.courseId)
          || !learnerPublicPostBlocked(request.resource.data.interactionSettingId))
        && request.resource.data.moderationStatus == 'visible';

      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid
        && (resource.data.studentVisibility != 'public'
          || isCourseInstructor(resource.data.courseId)
          || !learnerPublicPostBlocked(resource.data.interactionSettingId))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'body',
          'updatedAt'
        ])
        && request.resource.data.body is string;

      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'studentVisibility',
          'isDeleted',
          'deletedAt',
          'updatedAt'
        ])
        && request.resource.data.studentVisibility == 'teacherOnly'
        && request.resource.data.isDeleted == true;

      allow update: if signedIn()
        && isCourseInstructor(resource.data.courseId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'moderationStatus',
          'moderatedAt',
          'hiddenByTeacherIndividual',
          'hiddenByTeacherBulk'
        ])
        && request.resource.data.moderationStatus in ['visible', 'hiddenByTeacher'];

      allow update: if canUpdateAuthorSnapshotForCourseContent();

      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid
        && resource.data.moderationStatus != 'hiddenByTeacher';
    }

    match /publicLessonQuestionAnswers/{answerId} {
      function publicParentQuestionVisible() {
        return exists(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId))
          && get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.studentVisibility == 'public'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.moderationStatus == 'visible'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.isDeleted == false
          && lessonQuestionsPublicEnabled(get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.interactionSettingId)
          && !learnerPublicReadBlocked(get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.interactionSettingId);
      }

      function publicParentQuestionAllowsLearnerAnswers(questionId) {
        return exists(/databases/$(database)/documents/publicLessonQuestions/$(questionId))
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'public'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.moderationStatus == 'visible'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.isDeleted == false
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.target == 'everyone'
          && lessonQuestionsPublicEnabled(get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.interactionSettingId)
          && !learnerPublicPostBlocked(get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.interactionSettingId);
      }

      function publicParentQuestionAuthorCanAnswer(questionId) {
        return exists(/databases/$(database)/documents/publicLessonQuestions/$(questionId))
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'public'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.moderationStatus == 'visible'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.isDeleted == false
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorId == request.auth.uid
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorRole != 'teacher'
          && lessonQuestionsPublicEnabled(get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.interactionSettingId)
          && !learnerPublicPostBlocked(get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.interactionSettingId);
      }

      function teacherOnlyParentQuestionAuthorCanAnswer(questionId) {
        return exists(/databases/$(database)/documents/publicLessonQuestions/$(questionId))
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'teacherOnly'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.moderationStatus == 'visible'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.isDeleted == false
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorId == request.auth.uid
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorRole != 'teacher';
      }

      function publicParentQuestionBlocksOtherLearnerAnswers(questionId) {
        return exists(/databases/$(database)/documents/publicLessonQuestions/$(questionId))
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.studentVisibility == 'public'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.moderationStatus == 'visible'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.isDeleted == false
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorRole != 'teacher'
          && get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorId != request.auth.uid
          && !isCourseInstructor(get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.courseId)
          && learnerPublicPostBlockedForLearner(
            get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.interactionSettingId,
            get(/databases/$(database)/documents/publicLessonQuestions/$(questionId)).data.authorId
          );
      }

      function isPublicParentQuestionAuthor() {
        return exists(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId))
          && get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.authorId == request.auth.uid
          && (get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.authorRole != 'teacher'
            || hasActiveTeacherRole())
          && (!get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.keys().hasAny(['authorDisplayName'])
            || get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.authorDisplayName != '先生'
            || hasActiveTeacherRole());
      }

      function isParentQuestionCourseInstructor() {
        return exists(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId))
          && isCourseInstructor(
            get(/databases/$(database)/documents/publicLessonQuestions/$(resource.data.questionId)).data.courseId
          );
      }

      allow read: if signedIn()
        && ((resource.data.authorId == request.auth.uid
            && (resource.data.authorRole != 'teacher'
              || hasActiveTeacherRole()))
          || isPublicParentQuestionAuthor()
          || isParentQuestionCourseInstructor()
          || isCourseInstructor(resource.data.courseId)
          || (publicParentQuestionVisible()
            && resource.data.moderationStatus == 'visible'
            && resource.data.isDeleted == false));

      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isDeleted',
          'deletedAt',
          'updatedAt'
        ])
        && request.resource.data.isDeleted == true;

      allow create, update: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.answerId == answerId
        && request.resource.data.questionId is string
        && (!request.resource.data.keys().hasAny(['parentCommentId'])
          || request.resource.data.parentCommentId is string)
        && (!request.resource.data.keys().hasAny(['parentCommentType'])
          || request.resource.data.parentCommentType in ['question', 'answer'])
        && request.resource.data.courseId is string
        && request.resource.data.courseTitle is string
        && request.resource.data.lessonNumber is int
        && request.resource.data.lessonTitle is string
        && request.resource.data.body is string
        && request.resource.data.attachmentTypes is list
        && request.resource.data.isDeleted is bool
        && request.resource.data.moderationStatus in ['visible', 'hiddenByTeacher']
        && exists(/databases/$(database)/documents/publicLessonQuestions/$(request.resource.data.questionId))
        && get(/databases/$(database)/documents/publicLessonQuestions/$(request.resource.data.questionId)).data.moderationStatus == 'visible'
        && get(/databases/$(database)/documents/publicLessonQuestions/$(request.resource.data.questionId)).data.isDeleted == false
        && !publicParentQuestionBlocksOtherLearnerAnswers(request.resource.data.questionId)
        && (
          (get(/databases/$(database)/documents/publicLessonQuestions/$(request.resource.data.questionId)).data.studentVisibility == 'public'
            && validQuotedNoteCitationForPublicAudience(
              request.resource.data.courseId,
              request.resource.data.lessonNumber
            )
            && (publicParentQuestionAllowsLearnerAnswers(request.resource.data.questionId)
              || publicParentQuestionAuthorCanAnswer(request.resource.data.questionId)
              || isCourseInstructor(get(/databases/$(database)/documents/publicLessonQuestions/$(request.resource.data.questionId)).data.courseId)))
          || (get(/databases/$(database)/documents/publicLessonQuestions/$(request.resource.data.questionId)).data.studentVisibility == 'teacherOnly'
            && validQuotedNoteCitationForTeacherAudience(
              request.resource.data.courseId,
              request.resource.data.lessonNumber
            )
            && (teacherOnlyParentQuestionAuthorCanAnswer(request.resource.data.questionId)
              || isCourseInstructor(get(/databases/$(database)/documents/publicLessonQuestions/$(request.resource.data.questionId)).data.courseId)))
        );

      allow update: if signedIn()
        && isCourseInstructor(resource.data.courseId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'moderationStatus',
          'moderatedAt',
          'hiddenByTeacherIndividual',
          'hiddenByTeacherBulk'
        ])
        && request.resource.data.moderationStatus in ['visible', 'hiddenByTeacher'];

      allow update: if canUpdateAuthorSnapshotForCourseContent();
    }

    match /lessonInteractionSettings/{settingId} {
      allow read: if signedIn();

      allow create, update: if signedIn()
        && request.resource.data.courseId is string
        && isCourseInstructor(request.resource.data.courseId)
        && request.resource.data.lessonNumber is int
        && request.resource.data.lessonNotesPublicEnabled is bool
        && request.resource.data.lessonQuestionsPublicEnabled is bool;

      match /learnerRestrictions/{learnerId} {
        function parentSettingDoc() {
          return get(/databases/$(database)/documents/lessonInteractionSettings/$(settingId)).data;
        }

        function parentSettingExists() {
          return exists(/databases/$(database)/documents/lessonInteractionSettings/$(settingId));
        }

        allow read: if signedIn()
          && (
            request.auth.uid == learnerId
            || (parentSettingExists()
              && parentSettingDoc().courseId is string
              && isCourseInstructor(parentSettingDoc().courseId))
          );

        allow create, update: if signedIn()
          && parentSettingExists()
          && parentSettingDoc().courseId is string
          && isCourseInstructor(parentSettingDoc().courseId)
          && request.resource.data.courseId == parentSettingDoc().courseId
          && request.resource.data.lessonNumber == parentSettingDoc().lessonNumber
          && request.resource.data.learnerId == learnerId
          && request.resource.data.restrictionMode in ['none', 'noPublicPost', 'noPublicReadOrPost']
          && request.resource.data.updatedByUserId is string;
      }
    }

    match /courses/{courseId} {
      allow read: if signedIn() && resource.data.status == 'published';

      allow read: if signedIn()
        && resource.data.instructorId == request.auth.uid;

      allow read: if hasActiveTeacherRole()
        && resource.data.instructorId == request.auth.uid;

      allow create: if signedIn()
        && courseId.matches('sample-.*')
        && request.resource.data.status == 'published'
        && request.resource.data.source == 'developmentSeed'
        && validLessonContentVersionCreate();

      allow update: if signedIn()
        && courseId.matches('sample-.*')
        && request.resource.data.status == 'published'
        && request.resource.data.source == 'developmentSeed'
        && validCourseLessonUpdateInvariant()
        && validLessonContentVersionUpdate();

      allow create: if isTeacher()
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.status == 'published'
        && request.resource.data.source == 'teacherCreated'
        && request.resource.data.courseCode is string
        && request.resource.data.title is string
        && request.resource.data.lessons is list
        && validLessonContentVersionCreate();

      // CourseLesson, LessonEvent, and board-set data live inside arrays/maps.
      // Rules cannot iterate those nested values or prove that published media
      // arrays are append-only. The app validates per-item publication changes
      // transactionally for concurrency correctness, but that client check is
      // not a server security boundary. Rules enforce only document-level shape
      // plus lesson-count/version consistency without claiming stronger guarantees.
      allow update: if canUpdateOwnTeacherCourse();

      match /lessonDrafts/{lessonNumber} {
        function currentLessonContentVersion() {
          let courseData = get(
            /databases/$(database)/documents/courses/$(courseId)
          ).data;
          return courseData.keys().hasAny(['lessonContentVersion'])
            ? courseData.lessonContentVersion
            : 0;
        }

        function validLessonDraft() {
          return request.resource.data.keys().hasOnly([
              'lessonNumber',
              'boardSet',
              'baseLessonContentVersion',
              'draftRevision',
              'updatedAt'
            ])
            && lessonNumber.matches('^[1-9][0-9]{0,3}$')
            && request.resource.data.lessonNumber == lessonNumber
            && request.resource.data.boardSet is map
            && request.resource.data.boardSet.keys().hasOnly([
              'boards',
              'switchEvents'
            ])
            && request.resource.data.boardSet.boards is list
            && request.resource.data.boardSet.boards.size() <= 20
            && request.resource.data.boardSet.switchEvents is list
            && request.resource.data.boardSet.switchEvents.size() <= 10000
            && request.resource.data.baseLessonContentVersion is int
            && request.resource.data.baseLessonContentVersion
              == currentLessonContentVersion()
            && request.resource.data.draftRevision is int
            && request.resource.data.draftRevision >= 1
            && request.resource.data.draftRevision <= 2147483647
            && request.resource.data.updatedAt is timestamp;
        }

        allow read: if isCourseInstructor(courseId);
        allow create: if isCourseInstructor(courseId)
          && validLessonDraft()
          && request.resource.data.draftRevision == 1;
        allow update: if isCourseInstructor(courseId)
          && validLessonDraft()
          && (
            (!resource.data.keys().hasAny(['draftRevision'])
              && request.resource.data.draftRevision == 1)
            || (resource.data.draftRevision is int
              && resource.data.draftRevision >= 1
              && resource.data.draftRevision < 2147483647
              && request.resource.data.draftRevision
                == resource.data.draftRevision + 1)
          );
        allow delete: if isCourseInstructor(courseId);
      }

      match /participantIdentities/{userId} {
        function validIdentityPayload() {
          return request.resource.data.courseId == courseId
            && request.resource.data.userId == userId
            && request.resource.data.identityMode in ['profile', 'courseAlias']
            && request.resource.data.aliasConfiguredAtEnrollment is bool
            && request.resource.data.aliasRetired is bool
            && (!request.resource.data.keys().hasAny(['aliasDisplayName'])
              || request.resource.data.aliasDisplayName is string)
            && (!request.resource.data.keys().hasAny(['aliasAvatarColorName'])
              || request.resource.data.aliasAvatarColorName in [
                'blue',
                'green',
                'orange',
                'purple',
                'pink',
                'teal',
                'brown',
                'indigo'
              ])
            && (!request.resource.data.keys().hasAny(['sharedDisplayName'])
              || request.resource.data.sharedDisplayName is string)
            && (!request.resource.data.keys().hasAny(['sharedAvatarColorName'])
              || request.resource.data.sharedAvatarColorName in [
                'blue',
                'green',
                'orange',
                'purple',
                'pink',
                'teal',
                'brown',
                'indigo'
              ])
            && (!request.resource.data.keys().hasAny(['sharedBio'])
              || request.resource.data.sharedBio is string)
            && (!request.resource.data.keys().hasAny(['updatedByUserId'])
              || request.resource.data.updatedByUserId is string)
            && (!request.resource.data.keys().hasAny(['updatedByRole'])
              || request.resource.data.updatedByRole in ['student', 'teacher'])
            && (!request.resource.data.aliasConfiguredAtEnrollment
              || request.resource.data.aliasDisplayName is string);
        }

        allow read: if signedIn()
          && (
            request.auth.uid == userId
            || isCourseInstructor(courseId)
            || userHasCourseEnrollment(courseId)
          );

        allow create, update: if signedIn()
          && validIdentityPayload()
          && (
            (request.auth.uid == userId
              && request.resource.data.updatedByUserId == userId)
            || (isCourseInstructor(courseId)
              && request.resource.data.updatedByRole == 'teacher')
          );
      }

      match /teacherLegalNameShares/{userId} {
        allow read: if signedIn()
          && (request.auth.uid == userId
            || (isCourseInstructor(courseId)
              && coursePolicyAllowsInstructorLegalNameShare(courseId)));

        allow create, update: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.courseId == courseId
          && request.resource.data.userId == userId
          && validLegalNameValue(request.resource.data.legalName)
          && request.resource.data.acceptedPolicyVersion is int
          && request.resource.data.acceptedPolicyVersion >= 1;

        allow delete: if signedIn()
          && (request.auth.uid == userId || isCourseInstructor(courseId));
      }

      match /peerLegalNames/{token} {
        allow read: if signedIn()
          && coursePolicyAllowsPeerLegalNameShare(courseId)
          && (userHasCourseEnrollment(courseId) || isCourseInstructor(courseId));

        allow create, update: if signedIn()
          && userHasCourseEnrollment(courseId)
          && validLegalNameValue(request.resource.data.legalName)
          && request.resource.data.courseId == courseId
          && request.resource.data.acceptedPolicyVersion is int
          && request.resource.data.acceptedPolicyVersion >= 1
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/coursePrivacyConsents/$(courseId))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)/coursePrivacyConsents/$(courseId)).data.peerShareToken == token
          && get(/databases/$(database)/documents/users/$(request.auth.uid)/coursePrivacyConsents/$(courseId)).data.acceptedPeerLegalNameShare == true;

        allow delete: if signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/coursePrivacyConsents/$(courseId))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)/coursePrivacyConsents/$(courseId)).data.peerShareToken == token;
      }
    }
  }
}
