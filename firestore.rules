rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validWritableApplicationStatus(status) {
      return status in ['none', 'pending'];
    }

    function validExistingOrWritableApplicationStatus(newStatus, oldStatus) {
      return newStatus == oldStatus
        || newStatus in ['none', 'pending']
        || (newStatus == null && oldStatus == null);
    }

    function validTeacherApplicationStatusUpdate() {
      return request.resource.data.teacherApplicationStatus == resource.data.teacherApplicationStatus
        || ((resource.data.teacherApplicationStatus == null
          || resource.data.teacherApplicationStatus == 'none'
          || resource.data.teacherApplicationStatus == 'pending')
          && request.resource.data.teacherApplicationStatus == 'pending');
    }

    function validTeacherApplication() {
      return !request.resource.data.keys().hasAny(['teacherApplication'])
        || request.resource.data.teacherApplication is map;
    }

    function hasInitialStudentRole() {
      return request.resource.data.roles is list
        && request.resource.data.roles.size() == 1
        && request.resource.data.roles[0] == 'student'
        && request.resource.data.activeRole == 'student';
    }

    function keepsExistingRoles() {
      return request.resource.data.roles == resource.data.roles
        && request.resource.data.activeRole in resource.data.roles;
    }

    function onlyUpdatesTeacherApplicationFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'intendedUse',
        'teacherApplicationStatus',
        'teacherApplication',
        'updatedAt'
      ]);
    }

    function canSubmitTeacherApplication(userId) {
      return isOwner(userId)
        && onlyUpdatesTeacherApplicationFields()
        && request.resource.data.intendedUse == 'teacher'
        && request.resource.data.teacherApplicationStatus == 'pending'
        && (resource.data.teacherApplicationStatus == null
          || resource.data.teacherApplicationStatus == 'none'
          || resource.data.teacherApplicationStatus == 'pending')
        && validTeacherApplication();
    }

    function isTeacher() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['teacher']);
    }

    function canUpdateOwnTeacherCourse() {
      return isTeacher()
        && resource.data.instructorId == request.auth.uid
        && request.resource.data.instructorId == resource.data.instructorId
        && request.resource.data.courseCode == resource.data.courseCode
        && request.resource.data.source == resource.data.source
        && request.resource.data.status == resource.data.status
        && request.resource.data.lessons is list
        && request.resource.data.lessonCount is int;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'student'
        && hasInitialStudentRole()
        && request.resource.data.status == 'active'
        && request.resource.data.intendedUse in ['learner', 'teacher', 'organization']
        && validWritableApplicationStatus(request.resource.data.teacherApplicationStatus)
        && validWritableApplicationStatus(request.resource.data.organizationApplicationStatus)
        && validTeacherApplication();

      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && keepsExistingRoles()
        && request.resource.data.status == resource.data.status
        && request.resource.data.intendedUse in ['learner', 'teacher', 'organization']
        && validTeacherApplicationStatusUpdate()
        && validExistingOrWritableApplicationStatus(
          request.resource.data.organizationApplicationStatus,
          resource.data.organizationApplicationStatus
        )
        && validTeacherApplication();

      allow update: if canSubmitTeacherApplication(userId);

      match /enrollments/{courseId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.courseId == courseId
          && request.resource.data.status == 'inProgress'
          && request.resource.data.course is map
          && request.resource.data.lastLessonNumber is int
          && request.resource.data.lastLessonTitle is string;
      }

      match /learningEvents/{eventId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.type == 'lessonOpened'
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string;
      }

      match /lessonViewSessions/{sessionId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.cycleNumber is int
          && request.resource.data.status in ['inProgress', 'completed']
          && request.resource.data.hasPlaybackStarted is bool
          && request.resource.data.pendingCompletion is bool
          && request.resource.data.maxWatchedPositionSec is int
          && request.resource.data.totalDurationSec is int
          && request.resource.data.completionThresholdSec is int;
      }

      match /lessonViewSegments/{segmentId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.sessionId is string
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.cycleNumber is int
          && request.resource.data.status in ['inProgress', 'completed']
          && request.resource.data.studySeconds is int
          && request.resource.data.watchSeconds is int
          && request.resource.data.startPositionSec is int
          && request.resource.data.endPositionSec is int
          && request.resource.data.isDeleted is bool;
      }

      match /quizAttempts/{attemptId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.courseId is string
          && request.resource.data.courseTitle is string
          && request.resource.data.lessonNumber is int
          && request.resource.data.lessonTitle is string
          && request.resource.data.eventId is string
          && request.resource.data.question is string
          && request.resource.data.selectedChoiceIndex is int
          && request.resource.data.correctChoiceIndex is int
          && request.resource.data.isCorrect is bool;
      }

      match /courseSearchHistory/{historyId} {
        allow read: if isOwner(userId);

        allow create, update: if isOwner(userId)
          && request.resource.data.keyword is string
          && request.resource.data.normalizedKeyword is string;
      }
    }

    match /courses/{courseId} {
      allow read: if signedIn() && resource.data.status == 'published';

      allow read: if signedIn()
        && resource.data.instructorId == request.auth.uid;

      allow create, update: if signedIn()
        && courseId.matches('sample-.*')
        && request.resource.data.status == 'published'
        && request.resource.data.source == 'developmentSeed';

      allow create: if isTeacher()
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.status == 'published'
        && request.resource.data.source == 'teacherCreated'
        && request.resource.data.courseCode is string
        && request.resource.data.title is string
        && request.resource.data.lessons is list;

      allow update: if canUpdateOwnTeacherCourse();
    }
  }
}
